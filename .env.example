# Mr. Robot (Arch/Dev)
MR_ROBOT_BOT_TOKEN=xoxb-your-token
MR_ROBOT_APP_TOKEN=xapp-your-token
MR_ROBOT_GITHUB_APP_ID=
MR_ROBOT_GITHUB_PEM_PATH=~/.ssh/bike-shop-mr-robot.pem
MR_ROBOT_GITHUB_INSTALLATION_ID=

# Elliot Alderson (Dev/Arch)
ELLIOT_BOT_TOKEN=xoxb-your-token
ELLIOT_APP_TOKEN=xapp-your-token
ELLIOT_GITHUB_APP_ID=
ELLIOT_GITHUB_PEM_PATH=~/.ssh/bike-shop-elliot-alderson.pem
ELLIOT_GITHUB_INSTALLATION_ID=

# Tyrell Wellick (Tech PM/Dev)
TYRELL_BOT_TOKEN=xoxb-your-token
TYRELL_APP_TOKEN=xapp-your-token

# Project
PROJECT_LEAD_NAME=
PROJECT_LEAD_SLACK_ID=
AGENT_WORKSPACE=
# Directory where per-agent git worktrees are created. Must be separate from
# AGENT_WORKSPACE. Mandatory — agents refuse to start if this is not set.
# Example: /tmp/bike-shop-worktrees or ~/worktrees/bike-shop
AGENT_WORKTREE_DIR=

# Redis (Short-Term Memory)
REDIS_HOST=localhost
REDIS_PORT=6379

# Mem0 (Long-Term Memory)
QDRANT_HOST=localhost
QDRANT_PORT=6333
OLLAMA_URL=http://localhost:11434
ANTHROPIC_API_KEY=

# Claude CLI Timeouts
# CLAUDE_IDLE_TIMEOUT=300        # Kill after N seconds with no output (default: 300)
# CLAUDE_MAX_TIMEOUT=1800        # Absolute safety net (default: 1800)

# Langfuse (Observability) — global fallback
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Project paths and Langfuse keys (referenced in projects.yaml)
MARKET_ANALYSIS_REPO_PATH=/path/to/market-analysis
MARKET_ANALYSIS_WORKTREE_DIR=/path/to/market-analysis-worktrees
MARKET_ANALYSIS_LANGFUSE_PUBLIC_KEY=
MARKET_ANALYSIS_LANGFUSE_SECRET_KEY=
AUTARCH_REPO_PATH=/path/to/autarch
AUTARCH_WORKTREE_DIR=/path/to/autarch-worktrees
AUTARCH_LANGFUSE_PUBLIC_KEY=
AUTARCH_LANGFUSE_SECRET_KEY=

# MCP Services
NOTION_API_KEY=
