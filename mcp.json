{
  "mcpServers": {
    "memory-keeper": {
      "type": "stdio",
      "command": "npx",
      "args": ["mcp-memory-keeper"]
    },
    "notion": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "mcp-notion"],
      "env": {
        "NOTION_API_KEY": "${NOTION_API_KEY}"
      }
    },
    "drawio": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "drawio-mcp"],
      "env": {}
    },
    "excalidraw": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "excalidraw-mcp"],
      "env": {}
    }
  }
}
